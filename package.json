{
  "name": "ai-slop-tennis",
  "version": "1.0.0",
  "description": "Simplified tennis RPG with transparent stat-based simulation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "npm run build:node && node dist/test/basic-validation.js",
    "test:rally": "npm run build:node && node dist/test/testRallyAnalysis.js",
    "analyze": "npm run build:node && node dist/src/test/analysis/balanceAnalysis.js",
    "build:node": "tsc -p tsconfig.node.json",
    "clean": "rimraf dist"
  },
  "keywords": [
    "tennis",
    "rpg",
    "simulation",
    "game",
    "sports"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "devDependencies": {
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "rimraf": "^5.0.0",
    "tailwindcss": "3.4.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.14"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "mixpanel-browser": "^2.78.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.8"
  }
}
