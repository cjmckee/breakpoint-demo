{
  "name": "ai-slop-tennis",
  "version": "1.0.0",
  "description": "Simplified tennis RPG with transparent stat-based simulation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/test/basic-validation.js",
    "test": "tsc && node dist/test/basic-validation.js",
    "clean": "rimraf dist",
    "start": "node dist/index.js",
    "serve": "vite"
  },
  "keywords": [
