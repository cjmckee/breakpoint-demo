    "simulation",
    "game",
    "sports"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0",
