# Mixpanel project token — found at mixpanel.com under your project settings.
# Copy this file to .env.local for local dev, or set it as a GitHub Actions
# secret for production builds (see .github/workflows/ if you have a deploy workflow).
#
# Analytics are silently disabled if this variable is missing or still set to
# the placeholder value below.
VITE_MIXPANEL_TOKEN=your-mixpanel-token-here
